# Server
PORT=4000

# PostgreSQL
DATABASE_URL=postgres://root:root@localhost:5432/pharmaforge
PGSSL=false

# App JWT
APP_JWT_SECRET=change_this_super_secret
APP_JWT_EXPIRES=7d

# Firebase Admin
# Option 1: put the whole service account JSON in one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Option 2: use ADC via GOOGLE_APPLICATION_CREDENTIALS pointing to a json file path
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\deepa\PharmaForge-AI\pharmafirebase.json
